classDiagram

    class RoomType {
        +typeId: UUID
        +title: String
        +basePrice: Decimal
    }

    class RoomInventory {
        +inventoryId: UUID
        +typeId: UUID
        +date: Date
        +availableCount: int
    }

    class Booking {
        +bookingId: String
        +guestId: UUID
        +status: String
        +checkInDate: Date
        +checkOutDate: Date
        +lockedAt: Timestamp
        +expiresAt: Timestamp
    }

    class Guest {
        +guestId: UUID
        +fullName: String
        +email: String
    }

    %% Relationships
    RoomType "1" -- "*" RoomInventory : defines availability for
    RoomType "1" -- "*" Booking : reserved as
    RoomInventory "1" -- "*" Booking : manages stock for
    Guest "1" -- "*" Booking : owns